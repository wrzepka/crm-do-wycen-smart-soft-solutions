generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model client_addresses {
  id              Int     @id @default(autoincrement())
  client_id       Int     @unique
  city            String  @db.VarChar(100)
  postal_code     String  @db.VarChar(6)
  street          String  @db.VarChar(100)
  building_number String  @db.VarChar(20)
  nip             String  @db.VarChar(15)
  clients         clients @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_client_address")
}

model clients {
  id               Int               @id @default(autoincrement())
  first_name       String            @db.VarChar(100)
  last_name        String            @db.VarChar(100)
  is_lead          Boolean
  email            String            @unique @db.VarChar(150)
  phone            String?           @db.VarChar(30)
  client_addresses client_addresses?
  pricing_history  pricing_history[]
  projects         projects[]
}

model employee_technology {
  employee_id   Int
  technology_id Int
  employees     employees    @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  technologies  technologies @relation(fields: [technology_id], references: [id], onUpdate: NoAction)

  @@id([employee_id, technology_id])
  @@index([employee_id], map: "employee_technology_emp_idx")
  @@index([technology_id], map: "employee_technology_tech_idx")
}

enum EmployeeStatus {
  ACTIVE_AVAILABLE
  ACTIVE_BOOKED
  ON_LEAVE
  TERMINATED
  ONBOARDING
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model employees {
  id                  Int                   @id @default(autoincrement())
  first_name          String                @db.VarChar(100)
  last_name           String                @db.VarChar(100)
  busy_from           DateTime?             @db.Date
  busy_to             DateTime?             @db.Date
  status              EmployeeStatus        @default(ACTIVE_AVAILABLE)
  employee_technology employee_technology[]
  projects            projects[]
}

model pricing_history {
  id         Int      @id @default(autoincrement())
  client_id  Int
  project_id Int
  quote_date DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  cost       Decimal? @db.Decimal(12, 2)
  currency   String?  @default("PLN") @db.VarChar(3)
  status     String?  @default("draft") @db.VarChar(50)
  is_paid    Boolean? @default(false)
  notes      String?
  clients    clients  @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_history_client")
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_history_project")
}

model project_details {
  id              Int       @id @default(autoincrement())
  project_id      Int
  project_name    String?   @db.VarChar(200)
  description     String?
  technologies    String?
  estimated_hours Decimal?  @db.Decimal(10, 2)
  estimated_price Decimal?  @db.Decimal(12, 2)
  status          String?   @default("new") @db.VarChar(50)
  start_date      DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  end_date        DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  projects        projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_project_details")
}

model projects {
  id              Int               @id @default(autoincrement())
  client_id       Int
  employee_id     Int?
  pricing_history pricing_history[]
  project_details project_details[]
  clients         clients           @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_project_client")
  employees       employees?        @relation(fields: [employee_id], references: [id], map: "fk_project_employee")
}

model technologies {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique @db.VarChar(100)
  employee_technology employee_technology[]
}

enum Role {
  MANAGER
}

model users {
  id            String @id @default(cuid())
  email         String @unique @db.VarChar(150)
  password_hash String
  role          Role   @default(MANAGER)

  // Relations to other Auth.js models
  accounts Account[]
  sessions Session[]

  // Fields required by Auth.js v5 for profile and verification status
  emailVerified DateTime?
  image         String?
}

// The Account model stores information about OAuth accounts (Google, GitHub, etc.)
// linked to a specific user. It handles the link between the provider and your app.
model Account {
  id                String  @id @default(cuid())
  userId            String // Foreign key connecting this account to a User
  type              String // Type of account (e.g., "oauth", "oidc")
  provider          String // Name of the provider (e.g., "google", "github")
  providerAccountId String // Unique ID provided by the external auth service
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int? // Timestamp when the access token expires
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// The Session model is used for database-based sessions.
// It keeps track of active users and their session expiration.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique // Unique token sent to the browser via cookie
  userId       String // Reference to the user who owns this session
  expires      DateTime // When the session will automatically log out the user
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// The VerificationToken model stores temporary tokens used for passwordless login
// (Magic Links) or email verification processes.
model VerificationToken {
  identifier String // Typically the user's email address
  token      String   @unique // The secure random token sent to the user
  expires    DateTime // Expiration time for the token (usually short-lived)

  @@unique([identifier, token])
}
