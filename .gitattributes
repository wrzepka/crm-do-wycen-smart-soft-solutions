# Default setting for all files
* text=auto

# Enforce standard Line Endings (LF) for code files
# Next.js / React / TypeScript / CSS
*.js          text eol=lf
*.jsx         text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.json        text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.md          text eol=lf
.eslintrc.json text eol=lf
.prettierrc   text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf

# Identify binary files
# For images, PDF (which you generate), and fonts
*.png   binary
*.jpg   binary
*.jpeg  binary
*.svg   binary
*.gif   binary
*.pdf   binary
*.eot   binary
*.ttf   binary
*.woff  binary
*.woff2 binary